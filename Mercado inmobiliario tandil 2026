                    <li class="flex justify-between border-b border-slate-800 pb-2"><span class="text-slate-400 uppercase tracking-wide">Zona serrana / vistas naturales</span><span class="text-emerald-500">USD 1.800 – 2.800 /m²</span></li>
                    <li class="flex justify-between border-b border-slate-800 pb-2"><span class="text-slate-400 uppercase tracking-wide">Zona centro histórico</span><span class="text-emerald-500">USD 1.400 – 2.000 /m²</span></li>
                    <li class="flex justify-between border-b border-slate-800 pb-2"><span class="text-slate-400 uppercase tracking-wide">Barrios residenciales consolidados</span><span class="text-emerald-500">USD 1.000 – 1.500 /m²</span></li>
                    <li class="flex justify-between border-b border-slate-800 pb-2"><span class="text-slate-400 uppercase tracking-wide">Zona de expansión / periurbano</span><span class="text-emerald-500">USD 600 – 1.100 /m²</span></li>
                    <li class="flex justify-between"><span class="text-slate-400 uppercase tracking-wide">Tierras rurales / lotes productivos</span><span class="text-emerald-500">USD 8.000 – 25.000 /ha</span></li>
